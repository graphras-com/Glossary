# ── OpenAI (for AI-powered definition recommendations) ──
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_RECOMMENDATION_MODEL=gpt-4.1-mini

# ── Microsoft Entra ID Authentication ──
# Set AUTH_DISABLED=true to skip token validation (local dev only!)
AUTH_DISABLED=true
TENANT_ID=3a680226-db04-4df3-95bd-37b631e11597
API_AUDIENCE=api://d9785590-322c-48e6-ba58-a00aabb5aee5

# ── CORS ──
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Database ──
# For PostgreSQL (k8s with CloudNativePG):
# DATABASE_URL=postgresql://user:password@pg-rw.default.svc:5432/glossary
#
# For SQLite (local development, docker-compose):
DATABASE_PATH=./dictionary.db
